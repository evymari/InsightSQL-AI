# MCP Configuration
MCP_HOST=0.0.0.0
MCP_PORT=5000
MCP_TRANSPORT=http
MCP_DEFAULT_SOURCE=postgres

# Microsoft Fabric Configuration
SQL_SERVER_NAME=your-fabric-sql-endpoint.datawarehouse.fabric.microsoft.com
SQL_DATABASE_NAME=your_fabric_database
ODBC_DRIVER={ODBC Driver 18 for SQL Server}

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=insightsql

# Azure Authentication (for Fabric via AAD)
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id  
AZURE_CLIENT_SECRET=your_client_secret