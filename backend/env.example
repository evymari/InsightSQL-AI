# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/insightsql
POSTGRES_CONNECTION_STRING=postgresql://postgres:password@localhost:5432/insightsql

# MCP
MCP_SERVER_URL=http://localhost:5000
MCP_TRANSPORT=sse
MCP_TIMEOUT=30
MCP_RETRY_ATTEMPTS=3
USE_MCP_SCHEMA=true

# Data source selection
DEFAULT_DATA_SOURCE=postgres

# Fabric (optional)
FABRIC_CONNECTION_STRING=
FABRIC_SERVER_NAME=
FABRIC_DATABASE_NAME=
FABRIC_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# MCP server runtime
MCP_HOST=0.0.0.0
MCP_PORT=5000

# LLM Providers
OPENAI_AZURE_API_KEY=your_azure_api_key_here
OPENAI_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_AZURE_VERSION=2024-02-15-preview

# LLM Configuration
LLM_PROVIDER=anthropic
OPENAI_MODEL=gpt-4

# Application
DEBUG=True
HOST=0.0.0.0
PORT=8000
