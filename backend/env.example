# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/insightsql

# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_AZURE_API_KEY=your_azure_api_key_here
OPENAI_AZURE_VERSION=2024-02-15-preview

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
LLM_PROVIDER=anthropic
OPENAI_MODEL=gpt-4
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Application
DEBUG=True
HOST=0.0.0.0
PORT=8000
